# LLM provider: openai | anthropic | deepseek | ollama
LLM_PROVIDER=ollama

# Model for the chosen provider
# openai:    gpt-4o, gpt-4o-mini
# anthropic: claude-sonnet-4-6, claude-haiku-4-5-20251001
# deepseek:  deepseek-chat, deepseek-reasoner
# ollama:    mistral:latest, llama3.2:3b, ...
LLM_MODEL=mistral:latest

# Provider API keys (set the one matching LLM_PROVIDER)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# DEEPSEEK_API_KEY=sk-...

# Ollama server URL (only needed for ollama provider)
OLLAMA_BASE_URL=http://localhost:11434/v1

# Sampling temperature (default: 0.7)
# LLM_TEMPERATURE=0.7

# Max output tokens (default: 2500)
# LLM_MAX_TOKENS=2500

# Database URL (SQLite by default)
DATABASE_URL=sqlite:///./simwork.db

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000
